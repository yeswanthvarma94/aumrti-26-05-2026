# WARNING: AI provider keys must be set as Supabase Edge Function secrets, NOT as VITE_ vars.
# VITE_ vars are bundled into the client JS and visible to all users in the browser.
# Set them server-side: supabase secrets set OPENAI_API_KEY=sk-...
# The ai-proxy edge function reads these from Deno.env, not from the browser.
# These VITE_ keys below are intentionally blank in this example for that reason.

# AI Providers (optional — preferred path is Settings → API Hub → stored in api_configurations table)
VITE_ANTHROPIC_KEY=
VITE_OPENAI_KEY=

# Azure OpenAI (India Central — DPDP Act data residency).
# When all four are set, Azure OpenAI takes priority over generic OpenAI.
VITE_AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.openai.azure.com
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4o
VITE_AZURE_OPENAI_API_KEY=
VITE_AZURE_OPENAI_API_VERSION=2024-02-01

VITE_GEMINI_KEY=
VITE_PERPLEXITY_KEY=
VITE_SARVAM_KEY=
VITE_BHASHINI_KEY=
